# App
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dejoiy_portal?schema=public"
# Auth
JWT_SECRET=change-this-to-a-long-random-secret

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Mail
MAIL_FROM=noreply@corp.dejoiy.com

# Resend
RESEND_API_KEY=

# SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Keycloak
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=dejoiy
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=dejoiy-portal
KEYCLOAK_CLIENT_ID=dejoiy-portal
KEYCLOAK_CLIENT_SECRET=